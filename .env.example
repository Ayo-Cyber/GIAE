# Copy to `.env` and fill in. The compose file fails fast if required vars are missing.

# --- Postgres ---
POSTGRES_USER=giae
POSTGRES_PASSWORD=change-me
POSTGRES_DB=giae

# --- API auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-with-64-byte-random-string
JWT_ACCESS_TOKEN_TTL_MINUTES=60

# --- CORS ---
# Comma-separated. Localhost is fine for dev; lock down to your real domains in prod.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.giae.io

# --- Frontend ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-32-byte-random-string
NEXTAUTH_URL=http://localhost:3000

# --- Runtime ---
ENV=prod
